# Șablon de configurare — SE COMITE în git.
# Copiază-l în `web/.env` (care e în .gitignore) și completează valorile.
#
#   cp web/.env.example web/.env
#
# Vite expune în browser DOAR variabilele prefixate cu VITE_. Prefixul e o
# decizie conștientă: tot ce e aici ajunge în bundle-ul public. Cheile Firebase
# de client NU sunt secrete (sunt vizibile oricui deschide DevTools) — ele doar
# identifică proiectul. Securitatea reală stă în Security Rules și custom claims,
# nu în ascunderea acestor chei. NU pune aici secrete adevărate (chei de service
# account, parole) — acelea nu au ce căuta în frontend.

# Conectare la Firebase Emulator Suite în loc de cloud.
# true  → dezvoltare locală (M0–M6): fără card, fără costuri, date locale
# false → proiect Firebase real (abia de la M7)
VITE_USE_FIREBASE_EMULATORS=true

# Configurația proiectului Firebase.
# Pentru emulator, valorile pot fi fictive — contează doar projectId, care
# trebuie să fie identic cu cel din .firebaserc.
VITE_FIREBASE_PROJECT_ID=tenants-manager-2026
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=tenants-manager-2026.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=tenants-manager-2026.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
