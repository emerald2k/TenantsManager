# Configuration template — IT IS COMMITTED to git.
# Copy it to `web/.env` (which is in .gitignore) and fill in the values.
#
#   cp web/.env.example web/.env
#
# Vite exposes to the browser ONLY the variables prefixed with VITE_. The prefix
# is a deliberate decision: everything here ends up in the public bundle. The
# client Firebase keys are NOT secrets (they are visible to anyone who opens
# DevTools) — they only identify the project. The real security sits in the
# Security Rules and custom claims, not in hiding these keys. Do NOT put real
# secrets here (service account keys, passwords) — those have no place in the
# frontend.

# Connect to the Firebase Emulator Suite instead of the cloud.
# true  → local development (M0–M6): no card, no costs, local data
# false → real Firebase project (only from M7)
VITE_USE_FIREBASE_EMULATORS=true

# The Firebase project configuration.
# For the emulator, the values can be fictitious — only projectId matters, and it
# must be identical to the one in .firebaserc.
VITE_FIREBASE_PROJECT_ID=tenants-manager-2026
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=tenants-manager-2026.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=tenants-manager-2026.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
