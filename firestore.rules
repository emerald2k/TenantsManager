rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // The admin is identified EXCLUSIVELY through the custom claim in the token
    // (NFR-SEC-09). The token is already validated by Firebase by the time it
    // reaches here — we only read it.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // properties — admin-only access (SRS §7.3, NFR-SEC-02).
    //
    // The rule is an ACCESS boundary, not a business-logic one: it does NOT
    // filter archived properties here. `archived == false` is a display
    // preference and is applied in the query/hook (useProperties), where it can
    // also be turned off for the "Show archived" toggle (FR-PROP-07). A rule
    // filtering by `archived` would make the soft-delete (FR-PROP-06) look like
    // a real deletion and would block the admin from seeing their own archived data.
    match /properties/{propertyId} {
      allow read, write: if isAdmin();
    }

    // onboardingDrafts — admin-only access (SRS §6, NFR-SEC-02).
    //
    // The draft holds partial KYC data (the step 1-4 fields) before an account
    // exists; it is strictly admin-only, exactly like `users`. The tenant never
    // touches a draft — no account is created until KYC completion (FR-TEN-16,
    // FR-TEN-17). Deleted automatically on completion (FR-TEN-18) or manually
    // (FR-TEN-20); both are admin writes covered by this same rule.
    match /onboardingDrafts/{draftId} {
      allow read, write: if isAdmin();
    }

    // users — admin-only access (SRS §7.3, NFR-SEC-02): "admin = custom claim
    // admin==true → full access everywhere". The tenant never reads/writes this
    // collection directly — they only see denormalized data in `tenancies` and
    // their own published `monthlyReports` (CLAUDE.md §7). Needed now (Sub-stage C)
    // for the Step 1 live email/CNP checks (FR-TEN-07, FR-TEN-22), which read
    // `users` from the browser as the admin; previously only the Cloud Function
    // (Admin SDK, bypasses rules) had ever touched this collection.
    match /users/{userId} {
      allow read, write: if isAdmin();
    }

    // The remaining collections are not implemented yet.
    // Per-collection rules are added as the milestones progress, per SRS §7.3.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
