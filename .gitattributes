# Normalize line endings: LF both in the repo and in the working directory,
# regardless of the local core.autocrlf setting. Without this, on Windows the
# files would be checked out with CRLF, and Prettier (endOfLine: "lf") would flag
# every one of them as unformatted — a permanent conflict between git and the
# formatter.
* text=auto eol=lf

# Binary files — git must not touch their content.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary
